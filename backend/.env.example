# XENON Security Backend Configuration

# If you want to use a real email for password resets, uncomment and set the variables below.
# Otherwise, the system will automatically use a temporary Ethereal Email test account.
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com

# URL of the frontend app (useful if running Vite dev server locally)
# APP_PUBLIC_URL=http://localhost:5173
